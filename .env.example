# ── Frontend (.env.local) ────────────────────────────────────────────────────
# Copy relevant lines to frontend/.env.local

NEXT_PUBLIC_BACKEND_URL=http://localhost:8000


# ── Backend (.env) ───────────────────────────────────────────────────────────
# Copy relevant lines to backend/.env

# Prefer NeuralNote's native CLI when it is built. Use "basic-pitch" to force
# the previous Python runner, or "neuralnote_strict" to fail instead of fallback.
TRANSCRIPTION_ENGINE=neuralnote
# Optional if the CLI is not in vendor/NeuralNote/build/{Release,Debug}
# NEURALNOTE_CLI_PATH=C:\path\to\NeuralNoteCLI.exe

# MIDI refinement now runs locally (no MusicLang API key required).

# ElevenLabs API key for choir voice synthesis.
# Get one at https://elevenlabs.io
ELEVENLABS_API_KEY=sk_e93b735de4ceca6389eb402023538bc2aced46eea14308c5